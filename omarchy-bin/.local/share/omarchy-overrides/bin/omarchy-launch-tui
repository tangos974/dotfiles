#!/bin/bash
# Dotfiles override: Ghostty --gtk-single-instance=false avoids GTK single-instance
# stealing focus (e.g. Waybar clicks). uwsm-app matches stock Omarchy so the terminal
# still runs in the graphical session; bare "setsid ghostty" breaks menu-launched TUIs.
# Stowed to ~/.local/share/omarchy/bin/omarchy-launch-tui (see install-mullvad-browser.sh).
exec setsid uwsm-app -- ghostty --gtk-single-instance=false --class=org.omarchy.$(basename "$1") -e "$1" "${@:2}"
